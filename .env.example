# Application
APP_NAME=StyleStack API
ENVIRONMENT=development
STYLESTACK_DEBUG=false
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Firebase Admin SDK
# Paste the complete Firebase service-account JSON as a single-line JSON value.
# On Render, add this as a secret environment variable.
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
# Keep the service-role key server-side only. Never expose it to a browser/mobile app.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=wardrobe-images

# Automatically isolate clothing and composite it on a pure white background.
# The model downloads on first use; BiRefNet Lite gives much cleaner garment edges.
BACKGROUND_REMOVAL_ENABLED=true
BACKGROUND_REMOVAL_MODEL=birefnet-general-lite
FASHION_SEGMENTATION_ENABLED=true

# Groq Vision background tagging
GROQ_API_KEY=your-groq-api-key
GROQ_VISION_MODEL=qwen/qwen3.6-27b
GROQ_REQUEST_TIMEOUT_SECONDS=30
GROQ_REQUESTS_PER_MINUTE=30
GROQ_DEFAULT_RETRY_AFTER_SECONDS=2
AI_REQUESTS_PER_USER_PER_MINUTE=3
AI_REQUEST_QUEUE_MAX_SIZE=500
AI_REQUEST_JOB_RETENTION_SECONDS=3600

# Secondary AI provider used automatically when Groq is rate-limited or down.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_VISION_MODEL=gemini-flash-latest
PEXELS_API_KEY=your-pexels-api-key
PEXELS_BASE_URL=https://api.pexels.com/v1
PEXELS_REQUEST_TIMEOUT_SECONDS=8
PEXELS_RESULTS_PER_REQUEST=10
INSPIRATION_CLIP_ENABLED=false
INSPIRATION_CLIP_MODEL=openai/clip-vit-base-patch32
# Raw CLIP cosine similarity threshold. 0.28 is a conservative starting point;
# tune with real wardrobe examples because raw CLIP scores are not calibrated percentages.
INSPIRATION_CLIP_THRESHOLD=0.28
INSPIRATION_CLIP_REQUEST_TIMEOUT_SECONDS=12

# Weather-aware outfit suggestions
OPENWEATHER_API_KEY=your-openweather-api-key
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# Local Week 1 scheduler (replace with a durable scheduled worker later)
NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_POLL_SECONDS=60
GOOGLE_CALENDAR_AUTO_SYNC_ENABLED=true
# Background refresh interval for connected calendars (minimum 60 seconds).
GOOGLE_CALENDAR_SYNC_INTERVAL_SECONDS=300

# Development debugging only. Email subjects, senders, and 30-character
# content previews can contain personal data; keep this false on Render.
GMAIL_IMPORT_LOG_EMAIL_PREVIEWS=false

# Web OAuth client credentials used to exchange the mobile server auth code
# for a refresh token. The client ID must also be supplied to Flutter as
# GOOGLE_SERVER_CLIENT_ID. Never put the client secret in the Flutter app.
GOOGLE_OAUTH_CLIENT_ID=your-web-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-web-oauth-client-secret
GOOGLE_CALENDAR_AUTO_SYNC_ENABLED=true

# Zero-cost pilot guardrails. Keep true while usage is small; set false when
# you add a durable worker, shared rate limiter, or paid AI capacity.
FREE_PILOT_MODE=true
FREE_PILOT_AI_DAILY_LIMIT=3
FREE_PILOT_GMAIL_MAX_MESSAGES=10
FREE_PILOT_INSPIRATION_CACHE_SECONDS=86400
